# ============================================================
#  CRM Celexia — variables d'environnement (front Vite / SPA)
# ============================================================
# Copier ce fichier en `.env.local` puis remplir les valeurs.
# IMPORTANT : on n'embarque JAMAIS la clé `service_role` dans le front.
# Seule la clé `anon` (publique) est exposée ; la sécurité passe par la RLS.

# URL de ton projet Supabase (Settings → API → Project URL)
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co

# Clé publique "anon" (Settings → API → Project API keys → anon public)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR...

# ------------------------------------------------------------
# NOTE — ces valeurs NE vont PAS dans le front :
#  - N8N_WEBHOOK_URL  : se configure dans le dashboard Supabase
#                       (Database → Webhooks). Voir README §"Webhook n8n".
#  - SUPABASE_SERVICE_ROLE_KEY : ne jamais mettre ici ni dans le code front.
# ------------------------------------------------------------
